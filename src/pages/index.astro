---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Mission from '../components/Mission.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
	title="Mister LyA | Productos de Limpieza Profesional"
	description="Descubre nuestra amplia gama de productos de limpieza: escobas, traperos, jabones, esponjas y más. Calidad profesional para tu hogar o negocio."
>
	<Navbar />
	
	<main class="pt-20">
		<Hero />
		<Mission />
		<FeaturedProducts />
		<CTA />
	</main>
	
	<Footer />
	<WhatsAppButton />
</Layout>
