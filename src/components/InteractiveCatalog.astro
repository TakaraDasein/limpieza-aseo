---
import { categories, products } from '../data/catalog';

// Define background colors for each category
const categoryColors: Record<string, string> = {
  escobas: 'from-blue-50 via-blue-100 to-blue-50',
  cepillos: 'from-purple-50 via-purple-100 to-purple-50',
  traperos: 'from-green-50 via-green-100 to-green-50',
  jabones: 'from-cyan-50 via-cyan-100 to-cyan-50',
  esponjas: 'from-yellow-50 via-yellow-100 to-yellow-50',
  varios: 'from-pink-50 via-pink-100 to-pink-50'
};
---

<section 
  class="py-16 transition-all duration-700 bg-gradient-to-br from-surface via-surface-container-low to-surface" 
  id="products-section"
  data-active-category=""
>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
    
    <!-- Products by Category -->
    {categories.map((category, index) => {
      const categoryProducts = products.filter(p => p.category === category.id);
      const bgColor = categoryColors[category.id] || 'from-gray-50 via-gray-100 to-gray-50';
      
      return (
        <div 
          class="category-section mb-20 transition-all duration-500"
          id={`category-${category.id}`}
          data-category={category.id}
          style="display: none;"
        >
          <!-- Category Header with animated background -->
          <div class={`relative rounded-3xl p-8 md:p-12 mb-10 overflow-hidden bg-gradient-to-br ${bgColor}`}>
            <div class="absolute inset-0 opacity-10">
              <div class="absolute top-0 right-0 w-64 h-64 bg-primary rounded-full blur-3xl"></div>
              <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary rounded-full blur-3xl"></div>
            </div>
            
            <div class="relative z-10 flex items-center gap-6">
              <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-2xl shadow-lg flex items-center justify-center">
                <span class="material-symbols-outlined text-5xl md:text-6xl text-primary">{category.icon}</span>
              </div>
              <div>
                <h2 class="font-headline text-3xl md:text-5xl font-bold text-primary tracking-tight mb-2">
                  {category.name}
                </h2>
                <p class="text-on-surface-variant text-lg">{category.description}</p>
              </div>
            </div>
          </div>

          <!-- Products Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {categoryProducts.map((product, prodIndex) => (
              <div 
                class="product-card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 group"
                style={`animation-delay: ${prodIndex * 50}ms;`}
              >
                <div class="aspect-square overflow-hidden bg-surface-container-highest relative">
                  <img 
                    src={product.image} 
                    alt={product.name}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </div>
                
                <div class="p-6">
                  <h4 class="font-headline font-bold text-lg text-primary mb-2 line-clamp-2 group-hover:text-secondary transition-colors">
                    {product.name}
                  </h4>
                  <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">
                    {product.description}
                  </p>
                  
                  {product.variants && product.variants.length > 0 && (
                    <div class="mb-4">
                      <p class="text-xs font-semibold text-secondary mb-2">Variantes disponibles:</p>
                      <div class="flex flex-wrap gap-2">
                        {product.variants.map(variant => (
                          <span class="text-xs px-3 py-1 bg-surface-container rounded-full text-on-surface-variant">
                            {variant}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                  
                  <button 
                    class="w-full bg-primary text-on-primary py-3 rounded-xl font-bold hover:bg-primary-container hover:scale-95 transition-all flex items-center justify-center gap-2 group-hover:shadow-lg"
                    onclick={`window.open('https://wa.me/573115412230?text=Hola%2C%20quiero%20información%20sobre%20${encodeURIComponent(product.name)}', '_blank')`}
                  >
                    <span>Consultar</span>
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<script>
  // Reset product card animations when category changes
  document.addEventListener('DOMContentLoaded', () => {
    // Remove fade-in class from all products initially
    document.querySelectorAll('.product-card').forEach(card => {
      card.classList.remove('fade-in-up');
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .product-card {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .product-card.fade-in-up {
    animation: fadeInUp 0.5s ease-out forwards;
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Dynamic backgrounds based on active category */
  #products-section[data-active-category="escobas"] {
    background: linear-gradient(to bottom right, rgba(239, 246, 255, 0.5), var(--color-surface), rgba(239, 246, 255, 0.5));
  }
  
  #products-section[data-active-category="cepillos"] {
    background: linear-gradient(to bottom right, rgba(250, 245, 255, 0.5), var(--color-surface), rgba(250, 245, 255, 0.5));
  }
  
  #products-section[data-active-category="traperos"] {
    background: linear-gradient(to bottom right, rgba(240, 253, 244, 0.5), var(--color-surface), rgba(240, 253, 244, 0.5));
  }
  
  #products-section[data-active-category="jabones"] {
    background: linear-gradient(to bottom right, rgba(236, 254, 255, 0.5), var(--color-surface), rgba(236, 254, 255, 0.5));
  }
  
  #products-section[data-active-category="esponjas"] {
    background: linear-gradient(to bottom right, rgba(254, 252, 232, 0.5), var(--color-surface), rgba(254, 252, 232, 0.5));
  }
  
  #products-section[data-active-category="varios"] {
    background: linear-gradient(to bottom right, rgba(253, 242, 248, 0.5), var(--color-surface), rgba(253, 242, 248, 0.5));
  }
</style>
