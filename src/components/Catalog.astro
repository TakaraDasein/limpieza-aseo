---
import { categories, products } from '../data/catalog';
---

<section class="py-20 bg-surface-container-low" id="catalog">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-headline text-4xl md:text-6xl font-extrabold text-primary mb-6 tracking-tighter">
        Catálogo Completo
      </h2>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mx-auto">
        Descubre nuestra amplia gama de productos de limpieza profesional
      </p>
    </div>

    <!-- Categories Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-16">
      {categories.map(category => (
        <button 
          class="category-btn p-6 bg-white rounded-xl shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border-2 border-transparent hover:border-primary"
          data-category={category.id}
        >
          <span class="material-symbols-outlined text-4xl text-primary mb-3 block">{category.icon}</span>
          <h3 class="font-bold text-sm text-on-surface">{category.name}</h3>
        </button>
      ))}
    </div>

    <!-- Products by Category -->
    {categories.map(category => {
      const categoryProducts = products.filter(p => p.category === category.id);
      
      return (
        <div class="category-section mb-20" data-category={category.id}>
          <div class="flex items-center gap-4 mb-8">
            <span class="material-symbols-outlined text-5xl text-primary">{category.icon}</span>
            <div>
              <h3 class="font-headline text-3xl md:text-4xl font-bold text-primary tracking-tight">
                {category.name}
              </h3>
              <p class="text-on-surface-variant">{category.description}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {categoryProducts.map(product => (
              <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-2 group">
                <div class="aspect-square overflow-hidden bg-surface-container-highest">
                  <img 
                    src={product.image} 
                    alt={product.name}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  />
                </div>
                
                <div class="p-6">
                  <h4 class="font-headline font-bold text-lg text-primary mb-2 line-clamp-2">
                    {product.name}
                  </h4>
                  <p class="text-sm text-on-surface-variant mb-4 line-clamp-2">
                    {product.description}
                  </p>
                  
                  {product.variants && product.variants.length > 0 && (
                    <div class="mb-4">
                      <p class="text-xs font-semibold text-secondary mb-2">Variantes:</p>
                      <div class="flex flex-wrap gap-2">
                        {product.variants.map(variant => (
                          <span class="text-xs px-2 py-1 bg-surface-container rounded-full">
                            {variant}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                  
                  <button class="w-full bg-primary text-on-primary py-3 rounded-full font-bold hover:scale-95 transition-all flex items-center justify-center gap-2">
                    <span>Consultar</span>
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<script>
  // Category filtering (optional enhancement)
  const categoryBtns = document.querySelectorAll('.category-btn');
  const categorySections = document.querySelectorAll('.category-section');
  
  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const categoryId = btn.getAttribute('data-category');
      
      // Scroll to category section
      const section = document.querySelector(`[data-category="${categoryId}"].category-section`);
      if (section) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      
      // Highlight button
      categoryBtns.forEach(b => b.classList.remove('border-primary'));
      btn.classList.add('border-primary');
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
