---
---

<section class="relative px-6 py-24 md:px-12 md:py-32 overflow-hidden" id="home">
  <div class="max-w-screen-2xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="relative z-10">
      <h1 class="font-headline text-5xl md:text-8xl font-extrabold text-primary leading-[1.1] tracking-tighter mb-8">
        LyA <br/><span class="text-secondary italic">La esencia del cuidado</span>
      </h1>
      
      <div class="flex flex-wrap gap-5">
        <a class="bg-primary text-on-primary px-10 py-5 rounded-full font-bold text-lg hover:shadow-2xl hover:shadow-primary/30 transition-all active:scale-95" 
           href="/catalogo">
          Ver Catálogo
        </a>
      </div>
    </div>
    
    <div class="relative lg:h-[600px] flex items-center justify-center">
      <div class="absolute -top-12 -right-12 w-full h-full bg-secondary-fixed opacity-10 rounded-full blur-[100px] animate-pulse"></div>
      <div class="relative w-full max-w-2xl">
        <div class="relative rounded-3xl overflow-hidden shadow-2xl">
          <video 
            id="hero-video"
            class="w-full h-auto object-cover"
            autoplay
            loop
            muted
            playsinline
          >
            <source src="/v.mp4" type="video/mp4" />
            Tu navegador no soporta el elemento de video.
          </video>
          
          <!-- Botón de control de audio -->
          <button 
            id="audio-toggle"
            class="absolute bottom-6 right-6 bg-white/90 backdrop-blur-sm text-primary p-3 rounded-full hover:bg-white transition-all active:scale-95 shadow-lg hover:shadow-xl group"
            aria-label="Activar/Desactivar audio"
          >
            <span id="mute-icon" class="material-symbols-outlined">volume_off</span>
            <span id="unmute-icon" class="material-symbols-outlined hidden">volume_up</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  const audioToggle = document.getElementById('audio-toggle');
  const muteIcon = document.getElementById('mute-icon');
  const unmuteIcon = document.getElementById('unmute-icon');
  
  audioToggle?.addEventListener('click', () => {
    if (video.muted) {
      video.muted = false;
      muteIcon?.classList.add('hidden');
      unmuteIcon?.classList.remove('hidden');
    } else {
      video.muted = true;
      muteIcon?.classList.remove('hidden');
      unmuteIcon?.classList.add('hidden');
    }
  });
</script>
